{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"overrides": [
		{
			"includes": ["./apps/backend/src/**/*"],
			"linter": {
				"rules": {
					"style": {
						"useImportType": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"style": {
						"useConst": "off",
						"useImportType": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		}
	],
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"./apps/backend/src/**/*",
			"./apps/frontend/src/**/*",
			"./apps/frontend/vite.config.ts",
			"./packages/db/src/**/*"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		},
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
