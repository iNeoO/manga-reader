{
	"name": "manga-reader",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"backend:dev": "dotenv -e .env -- pnpm --filter @manga-reader/backend start:dev",
		"backend:build": "dotenv -e .env -- pnpm --filter @manga-reader/backend build",
		"frontend:dev": "dotenv -e .env -- pnpm --filter @manga-reader/frontend dev",
		"dev:libs:build": "pnpm run db:build",
		"dev:runtime": "concurrently -k \"pnpm run backend:dev\" \"pnpm run frontend:dev\"",
		"dev": "pnpm run dev:libs:build && pnpm run dev:runtime",
		"create:user": "dotenv -e .env -- pnpm --filter @manga-reader/scripts create-user",
		"delete:manga": "dotenv -e .env -- pnpm --filter @manga-reader/scripts delete-manga",
		"list:mangas": "dotenv -e .env -- pnpm --filter @manga-reader/scripts list-mangas",
		"upload:manga-dir": "dotenv -e .env -- pnpm --filter @manga-reader/scripts upload-manga-dir",
		"db:build": "dotenv -e .env -- pnpm --filter @manga-reader/db build",
		"db:generate": "dotenv -e .env -- pnpm --filter @manga-reader/db generate",
		"db:migrate": "dotenv -e .env -- pnpm --filter @manga-reader/db migrate",
		"db:deploy": "dotenv -e .env -- pnpm --filter @manga-reader/db deploy",
		"db:reset": "dotenv -e .env -- pnpm --filter @manga-reader/db reset",
		"lint": "pnpm -r run lint"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"dotenv-cli": "^11.0.0"
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	},
	"packageManager": "pnpm@10.32.1"
}
