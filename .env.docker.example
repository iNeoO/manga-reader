PG_MANGA_READER_USER=manga-reader
PG_MANGA_READER_DB=manga-reader
PG_MANGA_READER_PASSWORD=manga-reader-password
PG_URL=postgres://manga-reader:manga-reader-password@postgres:5432/manga-reader

PORT=4030
JWT_SECRET=change-me
COOKIE_SIGNATURE=change-me-too
VITE_COOKIE_TOKEN_NAME=auth_token
VITE_COOKIE_TOKEN_DURATION=30
VITE_COOKIE_TOKEN_SECURE=false
VITE_COOKIE_TOKEN_SAME_SITE=lax

S3_ENDPOINT=minio
S3_PORT=9000
S3_USE_SSL=false
